FLASK_ENV=development

# PostgreSQL (used by docker-compose)
POSTGRES_DB=civic_db
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic_secret

# Flask & JWT — MUST change in production
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-jwt-secret-in-production

# DATABASE_URL=postgresql://civic:civic_secret@localhost:5432/civic_db
